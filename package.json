{
  "name": "seo-analyzer",
  "version": "0.1.0",
  "private": true,
  "description": "SEO analyzer web app with Next.js, Supabase Auth, and GCP batch jobs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:sample": "node server.js",
    "gsc:check": "node scripts/gsc-connection-check.mjs",
    "ga4:check": "node scripts/ga4-connection-check.mjs",
